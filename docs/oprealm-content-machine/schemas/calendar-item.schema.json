{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "CalendarItem",
  "required": [
    "id",
    "workspaceId",
    "platform",
    "status",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "campaignId": {
      "type": "string"
    },
    "contentAtomId": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "socialAccountId": {
      "type": "string"
    },
    "assetVersionId": {
      "type": "string"
    },
    "caption": {
      "type": "string"
    },
    "hashtags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "scheduledAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "draft",
        "needs_changes",
        "approved",
        "scheduled",
        "publishing",
        "published",
        "failed",
        "cancelled",
        "manual_export_ready"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
