{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Campaign",
  "required": [
    "id",
    "workspaceId",
    "brandId",
    "status",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "brandId": {
      "type": "string",
      "minLength": 1
    },
    "creativeBriefId": {
      "type": "string"
    },
    "businessGoalId": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "strategy_ready",
        "qa_pending",
        "qa_passed",
        "active",
        "completed",
        "archived"
      ]
    },
    "pillars": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "angles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
