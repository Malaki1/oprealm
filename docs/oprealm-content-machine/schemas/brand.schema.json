{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Brand",
  "required": [
    "id",
    "workspaceId",
    "createdByUserId",
    "name",
    "status",
    "brandJson",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "createdByUserId": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "industry": {
      "type": "string"
    },
    "businessType": {
      "type": "string"
    },
    "productOrService": {
      "type": "string"
    },
    "offer": {
      "type": "string"
    },
    "primaryCTA": {
      "type": "string"
    },
    "targetAudience": {
      "type": "string"
    },
    "toneOfVoice": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "active",
        "archived"
      ]
    },
    "brandJson": {
      "type": "object",
      "additionalProperties": true
    },
    "archivedAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
