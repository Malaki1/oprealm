{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Workspace",
  "required": [
    "id",
    "name",
    "ownerUserId",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string"
    },
    "ownerUserId": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "enum": [
        "business",
        "friend",
        "client",
        "internal"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
