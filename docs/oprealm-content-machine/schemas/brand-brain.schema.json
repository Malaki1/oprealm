{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "BrandBrain",
  "required": [
    "id",
    "workspaceId",
    "brandId",
    "brainJson",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "brandId": {
      "type": "string",
      "minLength": 1
    },
    "brainJson": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": {
          "type": "string"
        },
        "offer": {
          "type": "string"
        },
        "primaryCTA": {
          "type": "string"
        },
        "audience": {
          "type": "string"
        },
        "painPoints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "objections": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "desiredOutcomes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "proofPoints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "testimonials": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "faqs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "toneOfVoice": {
          "type": "string"
        },
        "brandWords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "avoidWords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "visualIdentity": {
          "type": "object",
          "additionalProperties": true
        },
        "contentNotes": {
          "type": "string"
        },
        "agencyNotes": {
          "type": "string"
        },
        "sourceIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
