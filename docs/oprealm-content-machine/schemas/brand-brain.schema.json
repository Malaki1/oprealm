{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "BrandBrain",
  "required": [
    "id",
    "workspaceId",
    "brandId",
    "status",
    "name",
    "productOrService",
    "offer",
    "primaryCTA",
    "targetAudience",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "brandId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft_ready",
        "approved_for_generation",
        "needs_review",
        "archived"
      ]
    },
    "name": {
      "type": "string"
    },
    "industry": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "productOrService": {
      "type": "string"
    },
    "offer": {
      "type": "string"
    },
    "primaryCTA": {
      "type": "string"
    },
    "targetAudience": {
      "type": "string"
    },
    "painPoints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "objections": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "desiredOutcomes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "proofPoints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "testimonials": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "FAQs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "toneOfVoice": {
      "type": "string"
    },
    "brandWords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "avoidWords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "visualIdentity": {
      "type": "object",
      "additionalProperties": true
    },
    "sourceIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
