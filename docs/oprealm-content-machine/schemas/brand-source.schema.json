{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "BrandSource",
  "required": [
    "id",
    "workspaceId",
    "brandId",
    "createdByUserId",
    "sourceType",
    "status",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "brandId": {
      "type": "string",
      "minLength": 1
    },
    "createdByUserId": {
      "type": "string",
      "minLength": 1
    },
    "sourceType": {
      "enum": [
        "website_page",
        "manual_note",
        "uploaded_document",
        "source_video",
        "product_image",
        "logo",
        "testimonial",
        "faq",
        "existing_ad",
        "competitor_reference",
        "youtube_url",
        "social_profile",
        "other"
      ]
    },
    "sourceUrl": {
      "type": "string"
    },
    "assetId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "rawText": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "enum": [
        "pending",
        "active",
        "archived",
        "failed"
      ]
    },
    "archivedAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
