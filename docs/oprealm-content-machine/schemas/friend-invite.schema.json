{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "FriendInvite",
  "required": [
    "id",
    "workspaceId",
    "email",
    "status",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "tokenGrant": {
      "type": "number"
    },
    "status": {
      "enum": [
        "pending",
        "accepted",
        "expired",
        "revoked"
      ]
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
