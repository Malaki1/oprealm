{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "TokenPack",
  "required": [
    "id",
    "name",
    "tokens",
    "priceCents",
    "currency"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string"
    },
    "tokens": {
      "type": "number"
    },
    "priceCents": {
      "type": "number"
    },
    "currency": {
      "type": "string"
    },
    "active": {
      "type": "boolean"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
