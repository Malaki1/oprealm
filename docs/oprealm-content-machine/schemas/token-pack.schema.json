{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "TokenPack",
  "required": [
    "id",
    "name",
    "tokenAmount",
    "priceCents",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string"
    },
    "tokenAmount": {
      "type": "number"
    },
    "priceCents": {
      "type": "number"
    },
    "currency": {
      "type": "string"
    },
    "status": {
      "enum": [
        "active",
        "archived"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
