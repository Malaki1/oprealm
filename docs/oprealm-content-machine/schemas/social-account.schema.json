{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "SocialAccount",
  "required": [
    "id",
    "workspaceId",
    "platform",
    "status",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "externalAccountId": {
      "type": "string"
    },
    "status": {
      "enum": [
        "connected",
        "expired",
        "revoked",
        "manual_export"
      ]
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
